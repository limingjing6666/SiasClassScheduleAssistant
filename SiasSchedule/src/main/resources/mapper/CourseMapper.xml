<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sias.schedule.mapper.CourseMapper">

    <!-- 结果映射 -->
    <resultMap id="CourseResultMap" type="Course">
        <id property="id" column="id"/>
        <result property="studentId" column="student_id"/>
        <result property="name" column="name"/>
        <result property="teacher" column="teacher"/>
        <result property="room" column="room"/>
        <result property="day" column="day"/>
        <result property="nodes" column="nodes"/>
        <result property="weeks" column="weeks"/>
        <result property="semesterId" column="semester_id"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 根据学号查询课程列表 -->
    <select id="findByStudentId" resultMap="CourseResultMap">
        SELECT * FROM t_course WHERE student_id = #{studentId}
    </select>

    <!-- 根据学号和学期ID查询课程列表 -->
    <select id="findByStudentIdAndSemesterId" resultMap="CourseResultMap">
        SELECT * FROM t_course
        WHERE student_id = #{studentId} AND semester_id = #{semesterId}
    </select>

    <!-- 插入课程 -->
    <insert id="insert" parameterType="Course" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_course (student_id, name, teacher, room, day, nodes, weeks, semester_id, created_at, updated_at)
        VALUES (#{studentId}, #{name}, #{teacher}, #{room}, #{day}, #{nodes}, #{weeks}, #{semesterId}, NOW(), NOW())
    </insert>

    <!-- 批量插入课程 -->
    <insert id="batchInsert" parameterType="list">
        INSERT INTO t_course (student_id, name, teacher, room, day, nodes, weeks, semester_id, created_at, updated_at)
        VALUES
        <foreach collection="courses" item="course" separator=",">
            (#{course.studentId}, #{course.name}, #{course.teacher}, #{course.room},
             #{course.day}, #{course.nodes}, #{course.weeks}, #{course.semesterId}, NOW(), NOW())
        </foreach>
    </insert>

    <!-- 删除指定学号的所有课程 -->
    <delete id="deleteByStudentId">
        DELETE FROM t_course WHERE student_id = #{studentId}
    </delete>

    <!-- 删除指定学号和学期的所有课程 -->
    <delete id="deleteByStudentIdAndSemesterId">
        DELETE FROM t_course WHERE student_id = #{studentId} AND semester_id = #{semesterId}
    </delete>

</mapper>
